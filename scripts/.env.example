# Karakeep API connection
KARAKEEP_SERVER_ADDR=http://karakeep.local:3069
KARAKEEP_API_KEY=your_karakeep_api_key

# Optional defaults for scripts/export-karakeep-allowlist.py
KARAKEEP_OUTPUT_DIR=scripts/exports
KARAKEEP_ALLOWLIST_PATH=assets/Filter-3.txt

# Optional AdGuard Home conflict audit, used by: python scripts/export-karakeep-allowlist.py --check-adguard
ADGUARD_URL=http://adguard.local:3000
ADGUARD_USER=your_adguard_user
ADGUARD_PASSWORD=your_adguard_password
